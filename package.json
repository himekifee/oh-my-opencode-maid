{
  "name": "oh-my-opencode-maid",
  "version": "0.1.0",
  "description": "OpenCode plugin that rewrites assistant replies through a hidden rewrite agent.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "bun": ">=1.1.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tui": {
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/index.ts src/tui.ts --outdir dist --target bun --format esm --external @opencode-ai/plugin && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "keywords": [
    "opencode",
    "plugin",
    "rewrite",
    "roleplay"
  ],
  "dependencies": {
    "@opencode-ai/plugin": "^1.15.3",
    "@opencode-ai/sdk": "^1.15.3",
    "jsonc-parser": "^3.3.1",
    "zod": "4.1.8"
  },
  "devDependencies": {
    "bun-types": "^1.3.10",
    "typescript": "^5.8.2"
  }
}
